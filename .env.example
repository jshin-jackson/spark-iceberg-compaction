# Bash-safe .env — rules:
#   1) Quote values that contain spaces: KEY="value with spaces"
#   2) SPARK_CONF_* names must use underscores only (scripts map _ → . for Spark)
#   3) Copy to .env: cp .env.example .env

# ── CDP Spark connection ──
CDP_SPARK_MASTER=yarn
SPARK_QUEUE=maintenance

# ── Kerberos (CDP secure cluster) ──
KERBEROS_PRINCIPAL=systest@QE-INFRA-AD.CLOUDERA.COM
KERBEROS_KEYTAB=/cdep/keytabs/systest.keytab
SPARK_YARN_PRINCIPAL=systest@QE-INFRA-AD.CLOUDERA.COM
SPARK_YARN_KEYTAB=/cdep/keytabs/systest.keytab

# ── Auto-TLS truststore (confirm path in Cloudera Manager → Security → Certificates) ──
TRUSTSTORE_PATH=/var/lib/cloudera-scm-agent/agent/cert/cm-auto-global_cacerts.jks
TRUSTSTORE_PASSWORD=changeit
TRUSTSTORE_TYPE=JKS

# ── Iceberg catalog and target table ──
ICEBERG_CATALOG=spark_catalog
TARGET_DATABASE=your_database
TARGET_TABLE=your_iceberg_table

# Integration test aliases (pytest)
TEST_DATABASE=your_database
TEST_TABLE=your_iceberg_table

# Partition scope — must be quoted (contains spaces)
PARTITION_FILTER="business_date = DATE '2026-07-21'"
# Optional: predicate on {table}.files.partition struct (auto-derived from PARTITION_FILTER if unset)
# FILES_PARTITION_PREDICATE="partition.business_date = DATE '2026-07-21'"

# ── Metrics capture (step-wise verification) ──
# MAINTENANCE_RUN_ID=20260722_0100
# METRICS_DIR=./metrics/${MAINTENANCE_RUN_ID}

# ── Spark resources (maintenance dedicated queue recommended) ──
SPARK_EXECUTOR_MEMORY=8g
SPARK_DRIVER_MEMORY=4g
SPARK_NUM_EXECUTORS=4

# ── Spark / Iceberg (SPARK_CONF_ + underscores → spark.dotted.keys) ──
SPARK_CONF_spark_sql_catalog_spark_catalog=org.apache.iceberg.spark.SparkCatalog
SPARK_CONF_spark_sql_catalog_spark_catalog_type=hive
SPARK_CONF_spark_sql_extensions=org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions

# Optional: HDFS/Ozone HA, shuffle, AQE tuning
# SPARK_CONF_spark_sql_shuffle_partitions=200

# Safety gate for destructive integration tests (expire_snapshots, live orphan removal)
CDP_ALLOW_DESTRUCTIVE=false
